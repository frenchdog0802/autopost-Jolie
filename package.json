{
  "name": "autopost-jolie",
  "version": "0.1.0",
  "description": "LINE Bot auto-posting system for Instagram, Facebook, and Threads",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "format": "prettier --write \"src/**/*.ts\"",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "start": "node dist/index.js"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1068.0",
    "@line/bot-sdk": "^11.0.0",
    "dotenv": "^17.4.2",
    "express": "^4.21.2",
    "openai": "^6.42.0",
    "pino": "^10.3.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/express": "^4.17.21",
    "@types/node": "^22.13.10",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^3.0.9",
    "aws-sdk-client-mock": "^4.1.0",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "msw": "^2.14.6",
    "prettier": "^3.8.4",
    "supertest": "^7.2.2",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.61.0",
    "vitest": "^3.0.9"
  }
}
